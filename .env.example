# IgnisLink — environment variables
#
# Copy this file to `.env.local` (gitignored) and fill in real values for local dev.
# In staging/prod, secrets come from AWS Secrets Manager (see infra/, owned by Codex).
# NEVER commit a populated .env file. The .gitignore allows only `.env.example`.

# ─────────────────────────── Detection (Stage 1) ───────────────────────────

# NASA FIRMS API — VIIRS/MODIS thermal anomaly feeds.
# Get a key at https://firms.modaps.eosdis.nasa.gov/api/area/ (free).
FIRMS_API_KEY=

# Default bounding box for the FIRMS poller (CONUS-wide). Override per-region in admin UI.
FIRMS_BBOX_DEFAULT="-125,24,-66,50"
FIRMS_POLL_INTERVAL_SECONDS=60
FIRMS_CONFIDENCE_MIN=nominal      # nominal | high

# ─────────────────────────── Verification (Stage 1) ───────────────────────

# Firecrawl — web crawl + structured extract.
# https://www.firecrawl.dev/
FIRECRAWL_API_KEY=

# Exa — neural search across web/news.
# https://exa.ai/
EXA_API_KEY=

# NewsAPI.ai — news event aggregator.
# https://www.newsapi.ai/
NEWSAPI_AI_KEY=

# ─────────────────────────── Weather & terrain (Stage 2) ──────────────────

# NOAA HRRR — public, no key. Fetched from NOMADS or AWS Open Data.
# Open-Meteo fallback — free, no key required.
# Set the User-Agent for NOAA NOMADS courtesy.
NOAA_USER_AGENT="ignislink/0.1 (ops@example.org)"

# NASA Earthdata (SRTM elevation) — free with signup at urs.earthdata.nasa.gov.
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# USGS LANDFIRE — public, no key. Fetched from WMS/WFS endpoints; cache aggressively.

# ─────────────────────────── Maps & routing (Stage 4/5) ────────────────────

# Mapbox — basemap tiles, geocoding, directions, isochrones.
# Free tier covers dev. Get a token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=
MAPBOX_SECRET_TOKEN=

# ArcGIS Fire Stations REST — public, no key (HIFLD layer).

# ─────────────────────────── Dispatch (Stage 5) ───────────────────────────

# Twilio — SMS fallback channel for dispatch.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# RapidSOS IamResponding — partner CAD webhook (production credential, partner-issued).
RAPIDSOS_WEBHOOK_URL=
RAPIDSOS_HMAC_SECRET=

# ─────────────────────────── ML & data (Stage 3) ──────────────────────────

# MLflow tracking server (local default for dev; S3-backed in prod).
MLFLOW_TRACKING_URI=http://localhost:5000

# Modal / Lambda Labs (optional GPU compute for training).
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ─────────────────────────── Storage & infra (Stage 0+) ───────────────────

# Postgres — local docker-compose default; override per env.
DATABASE_URL=postgresql://ignis:ignis@localhost:5432/ignislink

# Redis — pub/sub + cache + rate limit.
REDIS_URL=redis://localhost:6379

# AWS — S3 for ML artifacts and raster cache; ECR for container images.
AWS_REGION=us-west-2
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─────────────────────────── Observability ───────────────────────────────

# Sentry — error tracking + tracing across web + api.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# OpenTelemetry — traces to Grafana Tempo / OTLP collector.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ignislink

# ─────────────────────────── Auth & API security ─────────────────────────

# JWT signing for the dispatcher console + admin (short-lived).
JWT_SECRET=
JWT_ISSUER=ignislink

# Per-partner webhook signing secrets — JSON-encoded map; one entry per CAD integrator.
# {"rapidsos":"shhh","municipal-cad-1":"shhh2"}
PARTNER_HMAC_SECRETS={}

# ─────────────────────────── Cameras (Stage 6) ───────────────────────────

# Pano AI public alerts (optional; partner-issued).
PANO_AI_API_KEY=

# YOLOv8 fire/smoke classifier — local model file path or S3 key.
YOLO_FIRE_MODEL_PATH=ml/models/yolo-fire-smoke-v1.onnx
