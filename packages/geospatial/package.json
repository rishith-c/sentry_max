{
  "name": "@sentry-max/geospatial",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Pure-function geospatial utilities for SentryMax: bbox math, geohash, polygon simplification, wind rose binning. No I/O.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vitest": "^2.1.3"
  }
}
