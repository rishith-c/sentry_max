{
  "name": "@ignislink/geospatial",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Pure-function geospatial utilities for IgnisLink: bbox math, geohash, polygon simplification, wind rose binning. No I/O.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo node_modules"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vitest": "^2.1.3"
  }
}
