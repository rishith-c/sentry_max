{
  "name": "@sentry-max/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shared shadcn/ui primitives + design tokens for SentryMax frontends.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "default": "./dist/tokens.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'no lint yet'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vitest": "^2.1.3"
  }
}
