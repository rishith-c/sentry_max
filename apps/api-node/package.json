{
  "name": "@ignislink/api-node",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Public alerts API and webhook fan-out edge for IgnisLink.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "echo 'no lint yet'",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@ignislink/contracts": "workspace:*",
    "hono": "^4.6.9",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "vitest": "^2.1.3"
  }
}
